# Frontend Environment Variables
# Copy this file to .env.local for local development
# For Vercel deployment, set these in the Vercel dashboard

# API Backend URL
# Production: Your deployed backend URL (e.g., Render, Railway, etc.)
# Development: Use localhost
VITE_API_URL=http://localhost:8002

# Blockchain RPC URL (optional - for blockchain features)
# Production: Infura/Alchemy URL or leave unset to disable blockchain
# Development: Local Ganache
VITE_BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Smart Contract Address (optional - for blockchain features)
# Set this after deploying your smart contract
VITE_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
